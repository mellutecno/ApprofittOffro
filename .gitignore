# Variabili d'ambiente e segreti
.env
functions/.env
functions/.runtimeconfig.json

# Credenziali OAuth Google
credentials.json
token.json

# File intermedi / temporanei
.tmp/
.test_profile/
.test_zip2/
deploy_staging/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# Database
approfittoffro.db
approfittoffro_copy.db
*.db

# Uploads
uploads/*
!uploads/
!uploads/.gitkeep

# OS
Thumbs.db
Desktop.ini
.DS_Store

*.apk
*.aab
*.jar
*.dex

# Flutter build
mobile_app/build/
mobile_app/.dart_tool/
mobile_app/.pub-cache/
mobile_app/android/.gradle/
mobile_app/android/app/build/
mobile_app/ios/
mobile_app/linux/
mobile_app/macos/
mobile_app/windows/
